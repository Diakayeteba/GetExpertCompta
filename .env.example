# Django
DJANGO_SETTINGS_MODULE=getexpertcompta.settings.development
SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# Développement rapide (sans PostgreSQL) :
DATABASE_URL=sqlite:///db.sqlite3
# Production / Docker (décommentez et adaptez) :
# POSTGRES_DB=getexpertcompta
# POSTGRES_USER=getexpertcompta
# POSTGRES_PASSWORD=getexpertcompta
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# DATABASE_URL=postgres://getexpertcompta:getexpertcompta@localhost:5432/getexpertcompta

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Security (production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@getexpertcompta.local

# File storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=

# Encryption (Fernet key for sensitive fields — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# Rate limiting / Axes
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Webhooks paiement (HMAC, hex digest comparé au header X-Signature)
WEBHOOK_SECRET_ORANGE=
WEBHOOK_SECRET_WAVE=
WEBHOOK_SECRET_MALITEL=

SITE_NAME=GetExpertCompta
SITE_DOMAIN=localhost:8000

# Free tier
FREE_TIER_EXPERT_PREVIEW_LIMIT=3
